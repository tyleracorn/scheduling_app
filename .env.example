# Database (docker compose default)
DATABASE_URL=postgresql://cabin:cabin@localhost:5432/cabin_scheduling

# Session signing (generate: openssl rand -base64 32)
SESSION_SECRET=change-me-to-a-long-random-string

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Seed admin (first deploy)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# SMTP (optional in dev — emails log to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
