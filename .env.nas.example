# Copy to .env on your NAS (same folder as docker-compose.nas.yml):
#   cp .env.nas.example .env
#
# Generate SESSION_SECRET (run on any machine):
#   openssl rand -base64 32

# --- Required ---

# Public URL users open in the browser (must match your reverse proxy / HTTPS hostname).
APP_URL=https://cabin.example.com

# Session cookie signing — use a long random string; changing it logs everyone out.
SESSION_SECRET=replace-with-openssl-rand-base64-32

# First admin account (created on first container start; password kept after you change it).
SEED_ADMIN_EMAIL=you@example.com
SEED_ADMIN_PASSWORD=use-a-strong-password-then-change-in-settings

# Optional: reset admin password from SEED_ADMIN_PASSWORD on next start (recovery only).
# FORCE_SEED_PASSWORD=true

# Do not set SEED_DEMO in production — it wipes/recreates demo periods on every start.

# Postgres (internal to compose; not exposed unless you publish db ports).
POSTGRES_USER=cabin
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=cabin_scheduling

# --- Image (GHCR) ---

APP_IMAGE_TAG=latest

# Host port for the app (reverse proxy can forward to this on the NAS IP).
APP_HOST_PORT=3000

# --- Optional: reverse proxy Docker network ---
# PROXY_NETWORK=proxy

# --- Optional: Postgres on a TrueNAS dataset ---
# POSTGRES_DATA_PATH=/mnt/tank/apps/cabin-scheduling/postgres

# --- Optional: SMTP (leave SMTP_HOST empty to log emails only) ---

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
