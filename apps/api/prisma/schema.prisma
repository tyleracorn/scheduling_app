generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PeriodStatus {
  scheduled
  open
  draft
  assignment
  published
  archived
}

enum DraftTurnStatus {
  pending
  active
  completed
}

enum DraftTurnAction {
  pick
  skip
  auto_skip
  coordinator_skip
  coordinator_pick
}

enum AssignmentSource {
  draft_pick
  coordinator_manual
  coordinator_edit
}

enum OccupancyStatus {
  green
  red
}

model Household {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  color        String   @db.Char(7)
  active       Boolean  @default(true)
  isWorkerBee  Boolean  @default(false) @map("is_worker_bee")
  isCoordinator Boolean @default(false) @map("is_coordinator")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships            HouseholdMembership[]
  notes                  CalendarNote[]
  occupancy              OccupancyIndicator[]
  periodPriorities       PeriodHouseholdPriority[]
  assignments            Assignment[]
  draftTurns             DraftTurn[]
  invites                Invite[]

  @@map("households")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  displayName     String    @map("display_name") @db.VarChar(100)
  isAdmin         Boolean   @default(false) @map("is_admin")
  active          Boolean   @default(true)
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  membership            HouseholdMembership?
  sessions              Session[]
  notesCreated          CalendarNote[]         @relation("NoteCreator")
  occupancyCreated      OccupancyIndicator[]   @relation("OccupancyCreator")
  periodsCreated        SchedulingPeriod[]     @relation("PeriodCreator")
  draftTurnsActed       DraftTurn[]            @relation("TurnActor")
  invitesSent           Invite[]               @relation("InviteSender")
  notifications         Notification[]
  auditEvents           AuditEvent[]
  passwordResetTokens   PasswordResetToken[]
  settingsUpdated       SystemSettings[]       @relation("SettingsUpdater")

  @@map("users")
}

model HouseholdMembership {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  householdId String   @map("household_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@map("household_memberships")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model SystemSettings {
  id                          Int      @id @default(1)
  cabinTimezone               String   @default("America/Denver") @map("cabin_timezone") @db.VarChar(64)
  weekStartDay                Int      @default(0) @map("week_start_day")
  weekSelectionsPerHousehold  Int      @default(1) @map("week_selections_per_household")
  pickWindowHours             Int      @default(72) @map("pick_window_hours")
  pickWarningLeadHours        Int      @default(12) @map("pick_warning_lead_hours")
  historyRetentionYears       Int      @default(3) @map("history_retention_years")
  periodFirstWeekStart        DateTime? @map("period_first_week_start") @db.Date
  periodWeekCount             Int      @default(13) @map("period_week_count")
  openLeadDays                Int      @default(30) @map("open_lead_days")
  periodsToSchedule           Int      @default(4) @map("periods_to_schedule")
  householdSlotCount          Int      @default(5) @map("household_slot_count")
  updatedAt                   DateTime @updatedAt @map("updated_at")
  updatedByUserId             String?  @map("updated_by_user_id") @db.Uuid

  updatedBy User? @relation("SettingsUpdater", fields: [updatedByUserId], references: [id])

  @@map("system_settings")
}

model SchedulingPeriod {
  id                    String       @id @default(uuid()) @db.Uuid
  name                  String       @db.VarChar(120)
  startDate             DateTime     @map("start_date") @db.Date
  endDate               DateTime     @map("end_date") @db.Date
  openingAt             DateTime     @map("opening_at")
  status                PeriodStatus @default(scheduled)
  draftStartedAt        DateTime?    @map("draft_started_at")
  publishedAt           DateTime?    @map("published_at")
  consecutiveAutoSkips  Int          @default(0) @map("consecutive_auto_skips")
  draftOnHold           Boolean      @default(false) @map("draft_on_hold")
  currentRound          Int          @default(1) @map("current_round")
  createdByUserId       String       @map("created_by_user_id") @db.Uuid
  createdAt             DateTime     @default(now()) @map("created_at")
  updatedAt             DateTime     @updatedAt @map("updated_at")

  createdBy   User                      @relation("PeriodCreator", fields: [createdByUserId], references: [id])
  weeks       PeriodWeek[]
  priorities  PeriodHouseholdPriority[]
  assignments Assignment[]
  draftTurns  DraftTurn[]

  @@index([status])
  @@index([startDate, endDate])
  @@map("scheduling_periods")
}

model PeriodWeek {
  id                 String   @id @default(uuid()) @db.Uuid
  schedulingPeriodId String   @map("scheduling_period_id") @db.Uuid
  weekStartDate      DateTime @map("week_start_date") @db.Date
  weekEndDate        DateTime @map("week_end_date") @db.Date
  sortOrder          Int      @map("sort_order")

  period      SchedulingPeriod @relation(fields: [schedulingPeriodId], references: [id], onDelete: Cascade)
  assignment  Assignment?
  draftTurns  DraftTurn[]

  @@unique([schedulingPeriodId, weekStartDate])
  @@map("period_weeks")
}

model PeriodHouseholdPriority {
  id                 String @id @default(uuid()) @db.Uuid
  schedulingPeriodId String @map("scheduling_period_id") @db.Uuid
  householdId        String @map("household_id") @db.Uuid
  position           Int

  period    SchedulingPeriod @relation(fields: [schedulingPeriodId], references: [id], onDelete: Cascade)
  household Household        @relation(fields: [householdId], references: [id])

  @@unique([schedulingPeriodId, householdId])
  @@unique([schedulingPeriodId, position])
  @@map("period_household_priorities")
}

model Assignment {
  id                 String           @id @default(uuid()) @db.Uuid
  schedulingPeriodId String           @map("scheduling_period_id") @db.Uuid
  periodWeekId       String           @unique @map("period_week_id") @db.Uuid
  householdId        String           @map("household_id") @db.Uuid
  source             AssignmentSource
  draftTurnId        String?          @unique @map("draft_turn_id") @db.Uuid
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  period    SchedulingPeriod @relation(fields: [schedulingPeriodId], references: [id], onDelete: Cascade)
  week      PeriodWeek       @relation(fields: [periodWeekId], references: [id])
  household Household        @relation(fields: [householdId], references: [id])
  draftTurn DraftTurn?       @relation(fields: [draftTurnId], references: [id])

  @@map("assignments")
}

model DraftTurn {
  id                 String           @id @default(uuid()) @db.Uuid
  schedulingPeriodId String           @map("scheduling_period_id") @db.Uuid
  householdId        String           @map("household_id") @db.Uuid
  round              Int
  positionInRound    Int              @map("position_in_round")
  status             DraftTurnStatus  @default(pending)
  action             DraftTurnAction?
  periodWeekId       String?          @map("period_week_id") @db.Uuid
  actedByUserId      String?          @map("acted_by_user_id") @db.Uuid
  startedAt          DateTime?        @map("started_at")
  expiresAt          DateTime?        @map("expires_at")
  warningSentAt      DateTime?        @map("warning_sent_at")
  completedAt        DateTime?        @map("completed_at")
  clientActionId     String?          @map("client_action_id") @db.Uuid

  period     SchedulingPeriod @relation(fields: [schedulingPeriodId], references: [id], onDelete: Cascade)
  household  Household        @relation(fields: [householdId], references: [id])
  week       PeriodWeek?      @relation(fields: [periodWeekId], references: [id])
  actedBy    User?            @relation("TurnActor", fields: [actedByUserId], references: [id])
  assignment Assignment?

  @@index([schedulingPeriodId, status])
  @@map("draft_turns")
}

model CalendarNote {
  id              String   @id @default(uuid()) @db.Uuid
  householdId     String   @map("household_id") @db.Uuid
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  body            String   @db.Text
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy User      @relation("NoteCreator", fields: [createdByUserId], references: [id])

  @@index([startDate, endDate])
  @@map("calendar_notes")
}

model OccupancyIndicator {
  id              String          @id @default(uuid()) @db.Uuid
  householdId     String          @map("household_id") @db.Uuid
  startDate       DateTime        @map("start_date") @db.Date
  endDate         DateTime        @map("end_date") @db.Date
  status          OccupancyStatus
  createdByUserId String          @map("created_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy User      @relation("OccupancyCreator", fields: [createdByUserId], references: [id])

  @@map("occupancy_indicators")
}

model Invite {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @db.VarChar(255)
  householdId     String    @map("household_id") @db.Uuid
  tokenHash       String    @map("token_hash") @db.VarChar(255)
  expiresAt       DateTime  @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  invitedByUserId String    @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")

  household Household @relation(fields: [householdId], references: [id])
  invitedBy User      @relation("InviteSender", fields: [invitedByUserId], references: [id])

  @@index([email])
  @@map("invites")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(200)
  body      String    @db.Text
  payload   Json      @default("{}")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}

model AuditEvent {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(50)
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  before      Json?
  after         Json?
  reason      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorUserId], references: [id])

  @@map("audit_events")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
